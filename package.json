{
  "name": "cloud-migrator",
  "version": "1.0.0",
  "description": "Multi-cloud object storage migrator",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "package": "pkg dist/index.js --targets node18-linux-x64 --output cloud-migrator"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "@azure/storage-blob": "^12.24.0",
    "@google-cloud/storage": "^7.11.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "figlet": "^1.7.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/figlet": "^1.5.8",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.14.0",
    "@types/node-fetch": "^2.6.11",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [],
    "targets": [
      "node18-linux-x64"
    ],
    "outputPath": "."
  }
}